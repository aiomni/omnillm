{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "rspress.config.ts",
    "theme/**/*.ts",
    "theme/**/*.tsx",
    "docs/components/**/*.ts",
    "docs/components/**/*.tsx"
  ]
}
