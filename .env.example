# Generic live Responses endpoint configuration.
# Copy to `.env` and fill in the values for your environment.

OMNI_GATEWAY_RESPONSES_BASE_URL=
OMNI_GATEWAY_RESPONSES_API_KEY=
OMNI_GATEWAY_RESPONSES_AUTH_SCHEME=bearer
OMNI_GATEWAY_RESPONSES_AUTH_NAME=
OMNI_GATEWAY_RESPONSES_EXTRA_HEADER_NAME=
OMNI_GATEWAY_RESPONSES_EXTRA_HEADER_VALUE=

OMNI_GATEWAY_RESPONSES_VISION_MODEL=
OMNI_GATEWAY_RESPONSES_TOOL_MODEL=
OMNI_GATEWAY_RESPONSES_IMAGE_URL=

# Optional overrides
OMNI_GATEWAY_RESPONSES_VISION_PROMPT=what is in this image?
OMNI_GATEWAY_RESPONSES_TOOL_PROMPT=What is the weather like in Boston today?
